# VClip Environment Configuration
# Copy to .env and adjust values
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ──────────────────────────────────────────────────────────────────
VCLIP_HOST=0.0.0.0
VCLIP_PORT=8000
VCLIP_DEBUG=false

# ── Paths ────────────────────────────────────────────────────────────────────
VCLIP_DATA_DIR=./data
VCLIP_DB_PATH=./data/vclip.db
VCLIP_TEMP_DIR=./data/tmp
VCLIP_CLIPS_DIR=./data/clips

# ── Whisper / STT ────────────────────────────────────────────────────────────
# Use medium for faster testing, large-v3 for production
VCLIP_WHISPER_MODEL=medium
VCLIP_WHISPER_DEVICE=auto      # auto, cpu, cuda, mps
VCLIP_WHISPER_COMPUTE=auto     # auto, float16, int8

# ── Concurrency ──────────────────────────────────────────────────────────────
MAX_CONCURRENT_JOBS=2

# ── Phase 3: AI / LLM re-ranking ─────────────────────────────────────────────
# Set to true to enable LLM re-ranking (requires OPENAI_API_KEY)
VCLIP_LLM_RERANK=false
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# ── Phase 4: Auth / JWT ───────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
VCLIP_JWT_SECRET=change-me-in-production-use-32-bytes
VCLIP_JWT_EXPIRE_MINUTES=10080    # 7 days

# Freemium limits
VCLIP_FREE_CLIPS_DAY=3            # clips/day for free tier
VCLIP_WATERMARK=true              # apply watermark to free-tier clips
VCLIP_WATERMARK_TEXT=Made with VClip

# YouTube OAuth2 (for upload integration)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REDIRECT_URI=http://localhost:8000/api/v1/auth/youtube/callback

# ── Phase 5: Public API + x402 ────────────────────────────────────────────────
VCLIP_RATE_LIMIT_RPM=60           # requests per minute per API key / IP
VCLIP_RATE_LIMIT_BURST=10

# x402 micropayment settings (leave blank to disable)
VCLIP_X402_PRICE=0.05             # USD per clip download
VCLIP_X402_WALLET=                # EVM wallet address on base-sepolia
VCLIP_X402_NETWORK=base-sepolia
