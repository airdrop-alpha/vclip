# VClip Environment Configuration
# Copy to .env and adjust values (this file is gitignored if you add it)
# For local .env: docker-compose will pick VCLIP_ prefixed vars directly

# Server
VCLIP_HOST=0.0.0.0
VCLIP_PORT=8000
VCLIP_DEBUG=false

# Paths (relative to backend/)
VCLIP_DATA_DIR=./data
VCLIP_DB_PATH=./data/vclip.db
VCLIP_TEMP_DIR=./data/tmp
VCLIP_CLIPS_DIR=./data/clips

# Whisper / STT
# Use medium for faster testing, large-v3 for production
VCLIP_WHISPER_MODEL=medium
VCLIP_WHISPER_DEVICE=auto
VCLIP_WHISPER_COMPUTE=auto

# Concurrency
MAX_CONCURRENT_JOBS=2

# Database
DATABASE_URL=sqlite:///./data/vclip.db
REDIS_URL=redis://localhost:6379
